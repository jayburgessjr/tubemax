<?xml version="1.0" encoding="utf-8" ?>
<component name="HeroBanner" extends="Group">

  <script type="text/brightscript" uri="pkg:/components/HeroBanner.brs" />

  <interface>
    <field id="apiKey"        type="string"     value="" onChange="onApiKeySet" />
    <field id="videoSelected" type="assocarray" />
    <field id="focused"       type="boolean"    value="false" onChange="onFocusedChanged" />
  </interface>

  <children>

    <!-- Full-screen hero backdrop -->
    <Poster
      id="heroThumb"
      width="1920"
      height="1080"
      loadDisplayMode="scaleToZoom"
      blendColor="0xCCCCCCFF"
    />

    <!-- Right-side darkening — keeps left content readable -->
    <Rectangle width="960" height="1080" color="0x00000044" translation="[960, 0]" />

    <!-- Left gradient — strong, like Netflix -->
    <Rectangle width="700" height="1080" color="0x000000EE" translation="[0,   0]" />
    <Rectangle width="400" height="1080" color="0x000000AA" translation="[700, 0]" />
    <Rectangle width="300" height="1080" color="0x00000066" translation="[1100, 0]" />

    <!-- Bottom gradient — rows area blends in from here -->
    <Rectangle width="1920" height="120" color="0x00000000" translation="[0, 440]" />
    <Rectangle width="1920" height="120" color="0x00000066" translation="[0, 560]" />
    <Rectangle width="1920" height="120" color="0x000000CC" translation="[0, 680]" />
    <Rectangle width="1920" height="160" color="0x000000FF" translation="[0, 800]" />

    <!-- Hero Content — lower-left, Netflix style -->
    <Group id="heroContent" translation="[80, 340]">

      <!-- Series label -->
      <Label
        id="seriesLabel"
        text="FEATURED"
        translation="[2, 0]"
        color="0xB3B3B3FF"
        font="font:SmallBoldSystemFont"
      />

      <!-- Large title -->
      <Label
        id="heroTitle"
        text="Loading..."
        translation="[0, 38]"
        width="780"
        wrap="true"
        color="0xFFFFFFFF"
        font="font:LargeBoldSystemFont"
      />

      <!-- Description -->
      <Label
        id="heroDesc"
        text=""
        translation="[0, 200]"
        width="620"
        wrap="true"
        color="0xE5E5E5FF"
        font="font:SmallSystemFont"
      />

      <!-- Buttons -->
      <Group id="btnGroup" translation="[0, 310]">

        <!-- Play — white solid -->
        <Rectangle
          id="playBtn"
          width="170" height="54"
          color="0xFFFFFFFF"
          cornerRadius="4"
          translation="[0, 0]"
        />
        <Label
          text="▶  Play"
          translation="[28, 15]"
          color="0x141414FF"
          font="font:MediumBoldSystemFont"
        />

        <!-- My List — semi-transparent -->
        <Rectangle
          id="infoBtn"
          width="170" height="54"
          color="0x808080AA"
          cornerRadius="4"
          translation="[186, 0]"
        />
        <Label
          text="+ My List"
          translation="[206, 15]"
          color="0xFFFFFFFF"
          font="font:MediumBoldSystemFont"
        />

      </Group>

    </Group>

  </children>

</component>
