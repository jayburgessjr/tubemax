<?xml version="1.0" encoding="utf-8" ?>
<component name="NavBar" extends="Group">

  <script type="text/brightscript" uri="pkg:/components/NavBar.brs" />

  <interface>
    <field id="activeTab" type="string" value="Home" onChange="onActiveTabChange" />
  </interface>

  <children>

    <!-- Background -->
    <Rectangle id="navBg" width="1920" height="72" color="0x080808FF" />
    <!-- Bottom border -->
    <Rectangle width="1920" height="1" color="0x1F1F1FFF" translation="[0, 71]" />

    <!-- TM Logo Mark (red badge) -->
    <Rectangle
      width="44" height="30" color="0xE50914FF"
      cornerRadius="4" translation="[24, 21]"
    />
    <Label
      text="TM"
      translation="[30, 24]"
      color="0xFFFFFFFF"
      font="font:SmallBoldSystemFont"
    />

    <!-- App name -->
    <Label
      text="TUBEMAX"
      translation="[78, 22]"
      color="0xFFFFFFFF"
      font="font:MediumBoldSystemFont"
    />

    <!-- Tab labels -->
    <Group id="navItems" translation="[380, 24]">
      <Label id="tab_Home"      text="Home"      translation="[0,   0]" color="0xFFFFFFFF" font="font:MediumBoldSystemFont" />
      <Label id="tab_Search"    text="Search"    translation="[150, 0]" color="0x808080FF" font="font:MediumSystemFont" />
      <Label id="tab_Trending"  text="Trending"  translation="[300, 0]" color="0x808080FF" font="font:MediumSystemFont" />
      <Label id="tab_Watchlist" text="Watchlist" translation="[470, 0]" color="0x808080FF" font="font:MediumSystemFont" />
    </Group>

    <!-- Active tab underline -->
    <Rectangle
      id="activeBar"
      width="46" height="3"
      color="0xE50914FF"
      cornerRadius="2"
      translation="[380, 62]"
    />

  </children>

</component>
