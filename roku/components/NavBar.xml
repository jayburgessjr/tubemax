<?xml version="1.0" encoding="utf-8" ?>
<component name="NavBar" extends="Group">

  <script type="text/brightscript" uri="pkg:/components/NavBar.brs" />

  <interface>
    <field id="activeTab" type="string" value="Home" onChange="onActiveTabChange" />
  </interface>

  <children>

    <!-- Nav solid base -->
    <Rectangle
      id="navBg"
      width="1920"
      height="100"
      color="0x0A0A0AFF"
    />
    <!-- Nav bottom fade into content -->
    <Rectangle width="1920" height="20" color="0x0A0A0A99" translation="[0, 100]" />
    <Rectangle width="1920" height="14" color="0x0A0A0A55" translation="[0, 120]" />

    <!-- Red left accent bar -->
    <Rectangle
      width="4"
      height="40"
      color="0xE50914FF"
      translation="[68, 30]"
    />

    <!-- TubeMax Logo -->
    <Label
      id="logoLabel"
      text="TUBEMAX"
      translation="[82, 33]"
      color="0xFFFFFFFF"
      font="font:LargeBoldSystemFont"
    />

    <!-- Nav Items -->
    <Group id="navItems" translation="[360, 38]">
      <Label id="tab_Home"      text="Home"        translation="[0,   0]" color="0xFFFFFFFF" font="font:MediumBoldSystemFont" />
      <Label id="tab_Search"    text="Search"      translation="[150, 0]" color="0x808080FF" font="font:MediumSystemFont" />
      <Label id="tab_Trending"  text="Trending"    translation="[300, 0]" color="0x808080FF" font="font:MediumSystemFont" />
      <Label id="tab_Watchlist" text="Watchlist"   translation="[470, 0]" color="0x808080FF" font="font:MediumSystemFont" />
    </Group>

    <!-- Active indicator bar -->
    <Rectangle
      id="activeBar"
      width="50"
      height="3"
      color="0xE50914FF"
      cornerRadius="2"
      translation="[360, 68]"
    />

  </children>

</component>
