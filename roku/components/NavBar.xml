<?xml version="1.0" encoding="utf-8" ?>
<component name="NavBar" extends="Group">

  <script type="text/brightscript" uri="pkg:/components/NavBar.brs" />

  <interface>
    <field id="activeTab" type="string" value="Home" onChange="onActiveTabChange" />
  </interface>

  <children>

    <!-- Gradient background: solid black at top, fades to transparent -->
    <Rectangle width="1920" height="22" color="0x000000FF" translation="[0,  0]" />
    <Rectangle width="1920" height="22" color="0x000000EE" translation="[0, 22]" />
    <Rectangle width="1920" height="20" color="0x000000AA" translation="[0, 44]" />
    <Rectangle width="1920" height="16" color="0x00000055" translation="[0, 64]" />

    <!-- TM Logo Mark -->
    <Rectangle
      width="40" height="28" color="0xE50914FF"
      cornerRadius="4" translation="[48, 26]"
    />
    <Label
      text="TM"
      translation="[53, 29]"
      color="0xFFFFFFFF"
      font="font:SmallBoldSystemFont"
    />

    <!-- App name -->
    <Label
      text="TUBEMAX"
      translation="[100, 24]"
      color="0xFFFFFFFF"
      font="font:MediumBoldSystemFont"
    />

    <!-- Tab labels -->
    <Group id="navItems" translation="[380, 26]">
      <Label id="tab_Home"      text="Home"      translation="[0,   0]" color="0xFFFFFFFF" font="font:MediumBoldSystemFont" />
      <Label id="tab_Search"    text="Search"    translation="[160, 0]" color="0xB3B3B3FF" font="font:MediumSystemFont" />
      <Label id="tab_Trending"  text="Trending"  translation="[320, 0]" color="0xB3B3B3FF" font="font:MediumSystemFont" />
      <Label id="tab_Watchlist" text="Watchlist" translation="[500, 0]" color="0xB3B3B3FF" font="font:MediumSystemFont" />
    </Group>

    <!-- Active tab underline -->
    <Rectangle
      id="activeBar"
      width="46" height="3"
      color="0xE50914FF"
      cornerRadius="2"
      translation="[380, 74]"
    />

  </children>

</component>
